# Veritabanı
DATABASE_URL=postgresql+asyncpg://hotelops:hotelpass@localhost:5432/hotelops

# JWT
JWT_SECRET_KEY=your-secret-key-change-this
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# Redis
REDIS_URL=redis://localhost:6379/0

# CORS (virgülle ayrılmış)
CORS_ORIGINS=http://localhost:3000,http://localhost:8000

# Debug modu
DEBUG=True
LOG_LEVEL=INFO

# LLM Sağlayıcısı (Faz 2)
LLM_PROVIDER=deepseek
DEEPSEEK_API_KEY=your-deepseek-key
OPENAI_API_KEY=your-openai-key
CLAUDE_API_KEY=your-claude-key
ENABLE_LLM_MOCK=false

# OTA Channel İntegasyonları (Faz 2)
BOOKING_COM_SECRET=your-booking-secret
EXPEDIA_KEY=your-expedia-key
AIRBNB_KEY=your-airbnb-key

# WhatsApp İntegrasyon (Faz 2)
WHATSAPP_API_TOKEN=your-whatsapp-token
WHATSAPP_APP_SECRET=your-whatsapp-secret
WHATSAPP_BUSINESS_ACCOUNT_ID=your-account-id

# GİB e-Fatura (Faz 2)
GIB_WSDL_URL=https://efatura.gib.gov.tr/soap
GIB_USERNAME=your-gib-username
GIB_PASSWORD=your-gib-password
