{
  "workspace": "./",
  "defaultLanguage": "python",
  "defaultModel": "claude-opus-4-1",
  "autoFormat": true,
  "extensions": [
    "python",
    "javascript",
    "git"
  ],
  "ai": {
    "providers": {
      "deepseek": {
        "enabled": true,
        "model": "deepseek-chat",
        "note": "API key from .env"
      },
      "claude_koray": {
        "enabled": true,
        "name": "Koray",
        "email": "korayumit@gmail.com",
        "model": "claude-opus-4-1"
      },
      "claude_umit": {
        "enabled": true,
        "name": "Umit",
        "email": "birumit@yandex.com.tr",
        "model": "claude-opus-4-1"
      },
      "gemini": {
        "enabled": true,
        "model": "gemini-2.0-flash",
        "note": "API key from .env, quota may be required"
      },
      "claude": {
        "enabled": true,
        "model": "claude-opus-4-1",
        "apiKey": "${ANTHROPIC_API_KEY}",
        "provider": "anthropic",
        "note": "Default Claude provider"
      },
      "openrouter": {
        "enabled": true,
        "model": "openrouter/auto",
        "apiKey": "${OPENROUTER_API_KEY}",
        "provider": "openrouter",
        "note": "100+ model access"
      }
    }
  },
  "terminal": {
    "environment": "loaded from .env file",
    "note": "All API keys and credentials loaded from .env"
  }
}
